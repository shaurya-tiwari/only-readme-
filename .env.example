# ============================================
# RideShield Environment Configuration
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://rideshield:rideshield123@localhost:5433/rideshield_db
DATABASE_URL_SYNC=postgresql://rideshield:rideshield123@localhost:5433/rideshield_db

# Application
APP_NAME=RideShield
APP_VERSION=0.1.0
DEBUG=true
SQL_ECHO=false
HOST=0.0.0.0
PORT=8000

# Simulation Mode (true = use mock APIs, false = use real APIs)
SIMULATION_MODE=true

# External APIs (used when SIMULATION_MODE=false)
OPENWEATHER_API_KEY=your_key_here
WAQI_API_KEY=your_key_here
TOMTOM_API_KEY=your_key_here

# Payments
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# Insurance Config
ACTIVATION_DELAY_HOURS=24
POLICY_DURATION_DAYS=7
MAX_PREMIUM_CHANGE_PERCENT=20
CLUSTER_FRAUD_THRESHOLD=5

# Trigger Thresholds
RAIN_THRESHOLD_MM=25.0
HEAT_THRESHOLD_C=44.0
AQI_THRESHOLD=300
TRAFFIC_THRESHOLD=0.75
PLATFORM_OUTAGE_THRESHOLD=0.60
SOCIAL_INACTIVITY_THRESHOLD=0.60
