# ============================================
# RideShield Environment Configuration
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://rideshield:rideshield123@localhost:5433/rideshield_db
DATABASE_URL_SYNC=postgresql://rideshield:rideshield123@localhost:5433/rideshield_db

# Application
APP_NAME=RideShield
APP_VERSION=0.1.0
DEBUG=true
SQL_ECHO=false
HOST=0.0.0.0
PORT=8000
SESSION_SECRET=change_me_to_a_long_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Simulation Mode (true = use mock APIs, false = use real APIs)
SIMULATION_MODE=true

# External APIs (used when SIMULATION_MODE=false)
OPENWEATHER_API_KEY=your_key_here
WAQI_API_KEY=your_key_here
TOMTOM_API_KEY=your_key_here

# Payments
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# Insurance Config
ACTIVATION_DELAY_HOURS=24
POLICY_DURATION_DAYS=7
MAX_PREMIUM_CHANGE_PERCENT=20
CLUSTER_FRAUD_THRESHOLD=5

# Trigger Thresholds
RAIN_THRESHOLD_MM=25.0
HEAT_THRESHOLD_C=44.0
AQI_THRESHOLD=300
TRAFFIC_THRESHOLD=0.75
PLATFORM_OUTAGE_THRESHOLD=0.60
SOCIAL_INACTIVITY_THRESHOLD=0.60

# Session Security (required for cross-origin Vercel → Render)
SESSION_COOKIE_SECURE=true          # true in prod (HTTPS only)
SESSION_COOKIE_SAMESITE=none        # none in prod (cross-origin), lax in dev

# Scheduler
ENABLE_TRIGGER_SCHEDULER=true
SCHEDULER_IN_PROCESS=false          # false = external worker (required on Render)
SCHEDULER_FETCH_CONCURRENCY=6
TRIGGER_CHECK_INTERVAL_SECONDS=300
TRAFFIC_DAILY_REQUEST_BUDGET=2400

# ML Artifact Directories
RISK_ML_ARTIFACT_DIR=backend/ml/artifacts_v2
FRAUD_ML_ARTIFACT_DIR=backend/ml/artifacts

# Signal Source Configuration
SIGNAL_SOURCE_MODE=mock             # mock | real | shadow
WEATHER_SOURCE=mock                 # mock | real
AQI_SOURCE=mock                     # mock | real
TRAFFIC_SOURCE=mock                 # mock | real
PLATFORM_SOURCE=mock                # mock | db | partner

# Phase 3 Feature Flags (all default OFF for safety)
ENABLE_DECISION_MEMORY=false
ENABLE_SHADOW_DIFF_LOGGING=false
ENABLE_SHADOW_DIFF_PERSISTENCE=false
ENABLE_PROVIDER_SNAPSHOT_PERSISTENCE=true
